# ID del servidor donde probar (Guild ID) - solo para desarrollo
GUILD_ID=TU_GUILD_ID_AQUI

# ID del rol de administrador del torneo (opcional)
ADMIN_ROLE_ID=TU_ROL_ADMIN_AQUI
